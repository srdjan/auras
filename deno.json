{
  "tasks": {
    "dev": "deno run --allow-net --allow-read jsr:@std/http/file-server . --host 127.0.0.1",
    "check": "deno check aura-components.js aura-diagram.js tests/aura-components.test.js tests/aura-tree.test.js tests/aura-diagram.test.js tests/aura-components.browser.test.js packages/components/mod.ts packages/diagram/mod.ts",
    "test": "deno test --allow-env=WS_NO_BUFFER_UTIL,WS_NO_UTF_8_VALIDATE tests/aura-components.test.js tests/aura-tree.test.js tests/aura-diagram.test.js",
    "test:browser": "deno test --allow-env --allow-read --allow-write --allow-net --allow-run --allow-sys tests/aura-components.browser.test.js",
    "publish:components:dry-run": "deno publish --dry-run --allow-dirty --config packages/components/jsr.json",
    "publish:diagram:dry-run": "deno publish --dry-run --allow-dirty --config packages/diagram/jsr.json"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"]
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  }
}
